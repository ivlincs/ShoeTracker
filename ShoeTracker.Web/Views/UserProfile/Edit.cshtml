@model ShoeTracker.Data.Models.Entities.UserProfile

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h2><i class="bi bi-pencil-square"></i> Edit Profile</h2>
            <form asp-action="Edit" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-control" placeholder="e.g. Sofia, Plovdiv..." />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Bio" class="form-label"></label>
                    <textarea asp-for="Bio" class="form-control" rows="4"
                              placeholder="Tell us about yourself..."></textarea>
                    <span asp-validation-for="Bio" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="YearlyGoal" class="form-label"></label>
                    <input asp-for="YearlyGoal" type="number" class="form-control" min="0" max="100000" />
                    <span asp-validation-for="YearlyGoal" class="text-danger"></span>
                    <small class="text-muted">Set your yearly running distance goal in km</small>
                </div>

                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-circle"></i> Save
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}