@using ShoeTracker.Common
@model PaginatedList<ShoeTracker.Data.Models.Entities.Shoe>

@{
    ViewData["Title"] = "My Running Shoes";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2><i class="bi bi-shoe-fill"></i> My Shoes</h2>
            <form method="get" asp-action="Index" class="mb-4">
                <div class="input-group">
                    <input type="text"
                           name="searchTerm"
                           value="@ViewData["SearchTerm"]"
                           class="form-control"
                           placeholder="Search by brand, model or category..." />
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Search
                    </button>
                    @if (!string.IsNullOrEmpty(ViewData["SearchTerm"]?.ToString()))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Clear
                        </a>
                    }
                </div>
                @if (!string.IsNullOrEmpty(ViewData["SearchTerm"]?.ToString()))
                {
                    <small class="text-muted mt-1 d-block">
                        @Model.TotalCount result(s) for "@ViewData["SearchTerm"]"
                    </small>
                }
            </form>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Add Shoe
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> You don't have any shoes yet. Add your first pair!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var shoe in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@shoe.Brand @shoe.Model</h5>
                            <p class="card-text">
                                <strong>Category:</strong> @shoe.Category.Name<br />
                                <strong>Mileage:</strong> @shoe.TotalDistance.ToString("F1") km<br />
                                <strong>Purchase:</strong> @shoe.PurchaseDate.ToString("dd.MM.yyyy")<br />
                                <strong>Runs:</strong> @shoe.Runs.Count
                            </p>

                            @{
                                double percentage = (shoe.TotalDistance / 600.0) * 100;
                                string progressClass = percentage < 50 ? "bg-success" : percentage < 80 ? "bg-warning" : "bg-danger";
                            }

                            <div class="progress mb-3" style="height: 25px;">
                                <div class="progress-bar @progressClass"
                                     role="progressbar"
                                     style="width: @Math.Min(percentage, 100)%">
                                    @percentage.ToString("F0")%
                                </div>
                            </div>

                            @if (shoe.TotalDistance >= 600)
                            {
                                <div class="alert alert-warning p-2 mb-3">
                                    <small><i class="bi bi-exclamation-triangle"></i> Time to replace!</small>
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-transparent">
                            <a asp-action="Details" asp-route-id="@shoe.Id" class="btn btn-sm btn-primary">Details</a>
                            <a asp-action="Edit" asp-route-id="@shoe.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@shoe.Id" class="btn btn-sm btn-danger">Delete</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Shoe pagination" class="mt-4">
                <ul class="pagination justify-content-center">
                    <!-- Previous Button -->
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-pageNumber="@(Model.PageIndex - 1)"
                           asp-route-searchTerm="@ViewData["SearchTerm"]">
                            ‹ Prev
                        </a>
                    </li>

                    <!-- Page Numbers -->
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-pageNumber="@i"
                               asp-route-searchTerm="@ViewData["SearchTerm"]">
                                @i
                            </a>
                        </li>
                    }

                    <!-- Next Button -->
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-pageNumber="@(Model.PageIndex + 1)"
                           asp-route-searchTerm="@ViewData["SearchTerm"]">
                            Next ›
                        </a>
                    </li>
                </ul>

                <!-- Page Info -->
                <p class="text-center text-muted small">
                    Page @Model.PageIndex of @Model.TotalPages
                    (@Model.TotalCount total shoes)
                </p>
            </nav>
        }
    }
</div>