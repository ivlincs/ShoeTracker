@using System.Security.Claims
@model ShoeTracker.Data.Models.Entities.Shoe

@{
	ViewData["Title"] = "Shoe Details";
}

<div class="container mt-4">
	<h2><i class="bi bi-info-circle"></i> @Model.Brand @Model.Model</h2>

	@if (TempData["SuccessMessage"] != null)
	{
		<div class="alert alert-success alert-dismissible fade show" role="alert">
			@TempData["SuccessMessage"]
			<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
		</div>
	}

	<div class="card mt-4">
		<div class="card-body">
			<dl class="row">
				<dt class="col-sm-3">Brand:</dt>
				<dd class="col-sm-9">@Model.Brand</dd>

				<dt class="col-sm-3">Model:</dt>
				<dd class="col-sm-9">@Model.Model</dd>

				<dt class="col-sm-3">Category:</dt>
				<dd class="col-sm-9">@Model.Category.Name</dd>

				<dt class="col-sm-3">Purchase Date:</dt>
				<dd class="col-sm-9">@Model.PurchaseDate.ToString("dd.MM.yyyy")</dd>

				<dt class="col-sm-3">Total Mileage:</dt>
				<dd class="col-sm-9">
					@Model.TotalDistance.ToString("F1") km
					@if (Model.TotalDistance >= 600)
					{
						<span class="badge bg-danger">Replace recommended!</span>
					}
				</dd>

				<dt class="col-sm-3">Number of Runs:</dt>
				<dd class="col-sm-9">@Model.Runs.Count</dd>
			</dl>

			@{
				var percentage = (Model.TotalDistance / 600.0) * 100;
				var progressClass = percentage < 50 ? "bg-success" : percentage < 80 ? "bg-warning" : "bg-danger";
			}

			<h5 class="mt-3">Shoe Wear:</h5>
			<div class="progress" style="height: 30px;">
				<div class="progress-bar @progressClass"
					 role="progressbar"
					 style="width: @Math.Min(percentage, 100)%">
					@percentage.ToString("F0")%
				</div>
			</div>
		</div>
	</div>
	@if (!string.IsNullOrWhiteSpace(Model.Notes))
	{
		<div class="card mt-3">
			<div class="card-header">
				<i class="bi bi-sticky"></i> Personal Notes
			</div>
			<div class="card-body">
				<p>@Model.Notes</p>
			</div>
		</div>
	}
	<div class="card mt-4">
		<div class="card-header">
			<h5><i class="bi bi-list-task"></i> Run History</h5>
		</div>
		<div class="card-body">
			@if (!Model.Runs.Any())
			{
				<p class="text-muted">No runs recorded yet.</p>
			}
			else
			{
				<table class="table table-striped">
					<thead>
						<tr>
							<th>Date</th>
							<th>Distance</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var run in Model.Runs.OrderByDescending(r => r.Date))
						{
							<tr>
								<td>@run.Date.ToString("dd.MM.yyyy HH:mm")</td>
								<td>@run.Distance.ToString("F1") km</td>
							</tr>
						}
					</tbody>
				</table>
			}
		</div>
	</div>

	<div class="mt-4">
		<a asp-controller="Run" asp-action="AddRun" asp-route-shoeId="@Model.Id" class="btn btn-success">
			<i class="bi bi-plus-circle"></i> Add Run
		</a>
		<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
			<i class="bi bi-pencil"></i> Edit
		</a>
		<a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
			<i class="bi bi-trash"></i> Delete
		</a>
		<a asp-action="Index" class="btn btn-secondary">Back to List</a>
	</div>

	<hr class="mt-4" />

	<h5><i class="bi bi-chat-dots"></i> Notes & Comments</h5>


	<form asp-controller="Comment" asp-action="Add" method="post" class="mb-4">
		@Html.AntiForgeryToken()
		<input type="hidden" name="shoeId" value="@Model.Id" />
		<div class="input-group">
			<input type="text" name="content" class="form-control"
				   placeholder="Add a note about this shoe..."
				   maxlength="500" />
			<button type="submit" class="btn btn-primary">
				<i class="bi bi-send"></i> Add Note
			</button>
		</div>
	</form>


	@if (ViewBag.Comments != null)
	{
		var comments = ViewBag.Comments as IEnumerable<ShoeTracker.Data.Models.Entities.Comment>;
		if (comments != null && comments.Any())
		{
			<div class="list-group">
				@foreach (var comment in comments)
				{
					<div class="list-group-item d-flex justify-content-between align-items-start">
						<div>
							<p class="mb-1">@comment.Content</p>
							<small class="text-muted">
								@comment.CreatedOn.ToString("dd MMM yyyy HH:mm")
							</small>
						</div>
						@if (comment.UserId == User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier))
						{
							<form asp-controller="Comment" asp-action="Delete" method="post">
								@Html.AntiForgeryToken()
								<input type="hidden" name="commentId" value="@comment.Id" />
								<input type="hidden" name="shoeId" value="@Model.Id" />
								<button type="submit" class="btn btn-sm btn-outline-danger">
									<i class="bi bi-trash"></i>
								</button>
							</form>
						}
					</div>
				}
			</div>
		}
		else
		{
			<p class="text-muted"><em>No notes yet. Be the first to add one!</em></p>
		}
	}
</div>