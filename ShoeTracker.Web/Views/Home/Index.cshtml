@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4">
        Welcome to ShoeTracker
    </h1>
    <p class="lead">Track your running shoes, monitor mileage, and stay injury-free!</p>
</div>

<div class="row mt-5">
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center d-flex flex-column">
                <i class="bi bi-card-checklist fs-1 text-primary"></i>
                <h5 class="card-title mt-3">Track Your Shoes</h5>
                <p class="card-text flex-grow-1">
                    Log all your running shoes and monitor their mileage in one convenient place.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center d-flex flex-column">
                <i class="bi bi-graph-up fs-1 text-success"></i>
                <h5 class="card-title mt-3">Monitor Progress</h5>
                <p class="card-text flex-grow-1">
                    Get notified at 600+ km mileage threshold to prevent injuries and stay healthy.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center d-flex flex-column">
                <i class="bi bi-bar-chart-line fs-1 text-info"></i>
                <h5 class="card-title mt-3">View Statistics</h5>
                <p class="card-text flex-grow-1">
                    Analyze your running data with interactive charts and insightful visualizations.
                </p>
            </div>
        </div>
    </div>
</div>

@if (User.Identity!.IsAuthenticated)
{
    <div class="text-center mt-5">
        <a asp-controller="Shoe" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="bi bi-card-checklist"></i> View My Shoes
        </a>
        <a asp-controller="Shoe" asp-action="Dashboard" class="btn btn-success btn-lg ms-2">
            <i class="bi bi-graph-up"></i> View Statistics
        </a>
    </div>
}
else
{
    <div class="text-center mt-5">
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg">
            <i class="bi bi-person-plus"></i> Get Started
        </a>
        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary btn-lg ms-2">
            <i class="bi bi-box-arrow-in-right"></i> Sign In
        </a>
    </div>
}