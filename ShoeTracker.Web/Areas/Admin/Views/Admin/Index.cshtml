@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h2><i class="bi bi-shield-lock"></i> Admin Dashboard</h2>
    <hr />

    <!-- Статистики Cards -->
    <div class="row mt-3">
        <!-- Card 1: Shoes -->
        <div class="col-6 col-md-3 mb-3">
            <div class="card text-white bg-primary text-center shadow-sm">
                <div class="card-body">
                    <i class="bi bi-shoe-fill fs-1"></i>
                    <h3>@ViewBag.TotalShoes</h3>
                    <p class="mb-0">Shoes</p>
                </div>
            </div>
        </div>

        <!-- Card 2: Users -->
        <div class="col-6 col-md-3 mb-3">
            <div class="card text-white bg-success text-center shadow-sm">
                <div class="card-body">
                    <i class="bi bi-person-fill fs-1"></i>
                    <h3>@ViewBag.TotalUsers</h3>
                    <p class="mb-0">Users</p>
                </div>
            </div>
        </div>

        <!-- Card 3: Runs -->
        <div class="col-6 col-md-3 mb-3">
            <div class="card text-white bg-info text-center shadow-sm">
                <div class="card-body">
                    <i class="bi bi-list-task fs-1"></i>
                    <h3>@ViewBag.TotalRuns</h3>
                    <p class="mb-0">Runs</p>
                </div>
            </div>
        </div>

        <!-- Card 4: Comments -->
        <div class="col-6 col-md-3 mb-3">
            <div class="card text-white bg-warning text-center shadow-sm">
                <div class="card-body">
                    <i class="bi bi-chat-dots fs-1"></i>
                    <h3>@ViewBag.TotalComments</h3>
                    <p class="mb-0">Comments</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Shoes Table -->
    <div class="card shadow-sm mt-3">
        <div class="card-header fw-bold">
            <i class="bi bi-clock-history"></i> Recent Shoes
        </div>
        <div class="card-body p-0">
            <div style="max-height: 500px; overflow-y: auto;">
                <table class="table table-hover mb-0">
                    <thead class="table-light" style="position: sticky; top: 0; z-index: 10;">
                        <tr>
                            <th>Brand</th>
                            <th>Model</th>
                            <th>Category</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var shoe in ViewBag.RecentShoes)
                        {
                            <tr>
                                <td>@shoe.Brand</td>
                                <td>@shoe.Model</td>
                                <td>@shoe.Category?.Name</td>
                                <td>@shoe.PurchaseDate.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" asp-area=""
           class="btn btn-outline-secondary">
            <i class="bi bi-house"></i> Back to Site
        </a>
    </div>
</div>